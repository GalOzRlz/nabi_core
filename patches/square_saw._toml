# maximal config:
[[program]]
function = "Square_saw_soft"
name = "soft square+saw"
tuning = "just intonation"
[program.config]
sqr_saw_mix = 0.5
[program.effects]
chain = ["eq", "drift", "reverb"] # order matters !
[program.effects.eq]
low_cut = 0.01
high_cut = 0.46
[program.effects.drift]
drift_amount = 0.345
[program.effects.reverb]
room_size = 0.8
damping = 0.5
length = 5.3
mix = 0.7
# all effects have different knobs, but they can share as well! frontend can alert and ask if a fix is needed.
[program.effects.eq.mapping]
low_cut = 3
high_cut = 4
[program.effects.drift.mapping]
drift = 2
[program.effects.reverb.mapping]
mix = 1

